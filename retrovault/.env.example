# RetroVault — Environment Variables
# Copy this file to .env.local and fill in the values you want to use.
# All variables are optional — RetroVault works without any of them.
#
#   cp .env.example .env.local

# ─── YouTube Videos ───────────────────────────────────────────────────────────
# Enables in-modal game playthrough / walkthrough videos.
# Free API key from: https://console.cloud.google.com
# Enable "YouTube Data API v3" → Create API Key
# Free quota: 10,000 units/day (100+ video lookups)
#
# YOUTUBE_API_KEY=AIzaSy...

# ─── Bug Reporting ────────────────────────────────────────────────────────────
# Enables the in-app 🐛 bug reporter that files issues directly to GitHub.
# Create a Fine-Grained Personal Access Token at:
#   https://github.com/settings/personal-access-tokens
# Permissions needed: Issues → Read and Write (on your repo only)
#
# GITHUB_ISSUES_TOKEN=github_pat_...

# ─── Session Security ─────────────────────────────────────────────────────────
# Secret used to sign session cookies when authentication is enabled.
# Generate a random string: openssl rand -hex 32
# If not set, a default is used (fine for local/LAN use, change for public).
#
# SESSION_SECRET=your-random-secret-here
